generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Customer {
  id        String         @id @default(cuid())
  name      String
  sheets    ReprintSheet[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model ReprintSheet {
  id           String          @id @default(cuid())
  customerId   String
  customer     Customer        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  jobName      String          @default("")
  jobDate      String          @default("")
  garmentType  String          @default("")
  garmentColor String          @default("")
  pieceCount   Int             @default(0)
  frontTime    String          @default("")
  backTime     String          @default("")
  dryerTemp    String          @default("")
  dryerSpeed   String          @default("")
  notes        String          @default("")
  carousel     String          @default("[]")
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  locations PrintLocation[]
  photos    Photo[]
  history   SheetHistory[]
}

model SheetHistory {
  id        String       @id @default(cuid())
  sheetId   String
  sheet     ReprintSheet @relation(fields: [sheetId], references: [id], onDelete: Cascade)
  action    String       // "created", "updated", "duplicated", "photo_added", "photo_deleted"
  changes   String       @default("{}") // JSON: { field: { from, to } }
  userId    String?      // future: user who made the change
  userName  String?      // future: display name
  createdAt DateTime     @default(now())
}

model PrintLocation {
  id           String       @id @default(cuid())
  sheetId      String
  sheet        ReprintSheet @relation(fields: [sheetId], references: [id], onDelete: Cascade)
  position     String       @default("FRONT")
  placement    String       @default("")
  size         String       @default("")
  inkColors    String       @default("")
  hasUnderbase Boolean      @default(false)
  hasWhite     Boolean      @default(false)
  notes        String       @default("")
  sortOrder    Int          @default(0)
}

model Photo {
  id           String       @id @default(cuid())
  sheetId      String
  sheet        ReprintSheet @relation(fields: [sheetId], references: [id], onDelete: Cascade)
  filename     String
  originalName String
  mimeType     String
  caption      String       @default("")
  createdAt    DateTime     @default(now())
}
